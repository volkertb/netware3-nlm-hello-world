#
# hello_old.def - NLM Header definition file for nlmconv(1)
# Copyright (c) 2000 Martin Hinner <martin@hinner.info>
#

# define startup object files
INPUT   hello_old.o
INPUT   /usr/nwsdk/lib/prelude.o            # clib startup code

# all imported functions and import lists
IMPORT @/usr/nwsdk/imports/clib.imp         # Functions in CLIB.NLM

# NLM header...
OUTPUT  hello_old.nlm                           # output file
TYPE 0                                      # 0 is Ordinary NLM (9 is Custom device module NLM)
VERSION 1,0,0                               # Version 1.0
COPYRIGHT "Copyright (c) 2000 Martin Hinner <martin@hinner.info>" # (c) ...
DESCRIPTION "Simple 'Hello world' NLM module." # title of nlm
SCREENNAME "System Console"                 # Default screen name

# Uncomment the OS_DOMAIN line if the NLM needs to run in Ring 0 with the OS
# (NOTE: this only has effect in NetWare 4.x or later, everything runs in Ring 0 in NetWare 3.x)
OS_DOMAIN

# 128 KiB: generous for a large application's call depth. NetWare 3.x ring-0 stacks have no
# guard pages, so overflow corrupts adjacent memory silently - err on the large side. Heap
# allocations don't come from this; only the stack does.
STACK 131072

MODULE CLIB                                 # req'd modules
