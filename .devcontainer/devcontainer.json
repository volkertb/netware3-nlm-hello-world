{
  // A QEMU sidecar (docs/qemu-vm-debugging.md) runs alongside `dev` as a second Compose
  // service - see docker-compose.yml. Array, not a single path: later files override/add to
  // earlier ones. docker-compose.podman-rootless.yml is Podman-only - Docker users, drop it
  // from this array (why: docs/devcontainer.md).
  "dockerComposeFile": ["docker-compose.yml", "docker-compose.podman-rootless.yml"],
  "service": "dev",
  // Required once a compose file is in play - Compose doesn't get the automatic workspace mount
  // a single-container `build` devcontainer does, so docker-compose.yml mounts it explicitly
  // and this just has to agree on the path.
  "workspaceFolder": "/workspaces/netware3-hello-world",
  // Gets rid of the "user was not specified" error in JetBrains IDEs at the end of the Podman container image build
  // Should be the same as the USER configured in the Dockerfile.
  // If no explicit USER is specified in the Dockerfile (which is recommended), this value should be set to "root".
  "containerUser": "dev-container-user",
  // Works around an open Podman bug in the CLI's post-build UID-sync step
  // (podman-container-tools/podman#23055). Docker users: flip this back to `true` (spec
  // default) - the bug is Podman-only. Full story, host-level alternative, and why this can't
  // be scoped to Podman-only the way dockerComposeFile above is: docs/devcontainer.md.
  "updateRemoteUserUID": false,
  // Optionally create your own .devcontainer/postCreate.local.sh (gitignored) to
  // symlink specific coding-agent config/state directories (e.g. ~/.claude) into
  // the agent-state volume (docker-compose.yml) mounted into `dev`, so they survive rebuilds.
  "postCreateCommand": "[ -f .devcontainer/postCreate.local.sh ] && bash .devcontainer/postCreate.local.sh || true"
}
